<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/colorBg">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Control de bomba" android:textSize="16sp" android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="14dp" android:layout_marginTop="4dp"/>

        <!-- Hero card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardCornerRadius="18dp"
            app:cardElevation="6dp" android:layout_marginBottom="14dp">
            <LinearLayout android:id="@+id/pump_hero_bg"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="24dp"
                android:background="@drawable/bg_hero_off">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bomba Principal" android:textSize="18sp"
                            android:textStyle="bold" android:textColor="#FFFFFF"/>
                        <TextView android:id="@+id/tv_pump_hero_sub"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Apagada · 110V / 50 PSI" android:textSize="13sp"
                            android:textColor="#CCFFFFFF" android:layout_marginTop="3dp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_pump_hero"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="false" style="@style/AgroSwitch"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:weightSum="3">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_stat_box" android:padding="10dp"
                        android:layout_marginEnd="4dp" android:gravity="center">
                        <TextView android:id="@+id/tv_pump_timer"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="00:00" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ACTIVO" android:textSize="10sp" android:textColor="#AAFFFFFF" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_stat_box" android:padding="10dp"
                        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="110V" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="VOLTAJE" android:textSize="10sp" android:textColor="#AAFFFFFF" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_stat_box" android:padding="10dp"
                        android:layout_marginStart="4dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="50 PSI" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="PRESIÓN" android:textSize="10sp" android:textColor="#AAFFFFFF" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Auto-riego -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="18dp" app:cardElevation="2dp" android:layout_marginBottom="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🤖 Auto-riego por humedad"
                        android:textSize="12sp" android:textColor="@color/colorTextPrimary" android:textStyle="bold"/>
                    <TextView android:id="@+id/badge_auto"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Activo" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/chipOkText" android:background="@drawable/bg_chip_ok"
                        android:paddingStart="12dp" android:paddingEnd="12dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"/>
                </LinearLayout>
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Activar si humedad &lt;"
                        android:textSize="13sp" android:textColor="@color/colorTextSecondary"/>
                    <TextView android:id="@+id/tv_threshold_val"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="40%" android:textSize="14sp"
                        android:textColor="@color/colorTextPrimary" android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekbar_threshold"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="95" android:progress="40"
                    android:progressTint="@color/green_primary" android:thumbTint="@color/green_primary"
                    android:layout_marginBottom="12dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <View android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/bg_dot_green" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tv_auto_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Esperando datos del sensor..."
                        android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:textStyle="bold"/>
                </LinearLayout>


            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Programación — con hora y duración editables -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="18dp" app:cardElevation="2dp" android:layout_marginBottom="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🗓 Programación de riego"
                        android:textSize="14sp" android:textColor="@color/colorTextPrimary" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_sched_badge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2 activos" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/chipInfoText" android:background="@drawable/bg_chip_info"
                        android:paddingStart="12dp" android:paddingEnd="12dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginTop="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Límite diario de riegos"
                        android:textSize="12sp" android:textColor="@color/chipOkText"/>
                    <TextView android:id="@+id/tv_max_pumps"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0 riegos/día" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"
                        android:background="@drawable/bg_schedule_time"
                        android:paddingStart="12dp" android:paddingEnd="12dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>


                <!-- Horario 1 — clickeable para editar -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingTop="12dp" android:paddingBottom="12dp">
                    <LinearLayout android:layout_width="64dp" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/bg_schedule_time"
                        android:padding="8dp" android:gravity="center" android:layout_marginEnd="12dp"
                        android:id="@+id/tv_sched1_time_container"
                        android:clickable="true" android:focusable="true">
                        <TextView android:id="@+id/tv_sched1_time"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="06:30" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/colorTextPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✎" android:textSize="10sp"
                            android:textColor="@color/green_primary" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Riego matutino" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="@color/colorTextPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Lun · Mar · Mié · Jue · Vie" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tv_sched1_duration"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="15 min" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/colorTextSecondary"
                        android:background="@drawable/bg_schedule_time"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="10dp"
                        android:clickable="true" android:focusable="true"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_sched1" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:checked="true" style="@style/AgroSwitch"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/colorBorder"/>

                <!-- Horario 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingTop="12dp" android:paddingBottom="12dp">
                    <LinearLayout android:layout_width="64dp" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/bg_schedule_time"
                        android:padding="8dp" android:gravity="center" android:layout_marginEnd="12dp"
                        android:id="@+id/tv_sched2_time_container"
                        android:clickable="true" android:focusable="true">
                        <TextView android:id="@+id/tv_sched2_time"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="18:00" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/colorTextPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✎" android:textSize="10sp"
                            android:textColor="@color/green_primary" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Riego vespertino" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="@color/colorTextPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Todos los días" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tv_sched2_duration"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="10 min" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/colorTextSecondary"
                        android:background="@drawable/bg_schedule_time"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="10dp"
                        android:clickable="true" android:focusable="true"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_sched2" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:checked="true" style="@style/AgroSwitch"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/colorBorder"/>

                <!-- Horario 3 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingTop="12dp">
                    <LinearLayout android:layout_width="64dp" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/bg_schedule_time"
                        android:padding="8dp" android:gravity="center" android:layout_marginEnd="12dp"
                        android:id="@+id/tv_sched3_time_container"
                        android:clickable="true" android:focusable="true">
                        <TextView android:id="@+id/tv_sched3_time"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="12:00" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/colorTextPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✎" android:textSize="10sp"
                            android:textColor="@color/green_primary" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fin de semana" android:textSize="13sp"
                            android:textStyle="bold" android:textColor="@color/colorTextPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sáb · Dom" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tv_sched3_duration"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="20 min" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/colorTextSecondary"
                        android:background="@drawable/bg_schedule_time"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="10dp"
                        android:clickable="true" android:focusable="true"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_sched3" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:checked="false" style="@style/AgroSwitch"/>
                </LinearLayout>

                <!-- Hint edición -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✎ Toca la hora o duración para editar"
                    android:textSize="11sp" android:textColor="@color/colorTextSecondary"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Resumen de hoy -->
        <androidx.cardview.widget.CardView android:id="@+id/card_resumen"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="18dp" app:cardElevation="2dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true" android:focusable="true"
            android:layout_marginBottom="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📊 Resumen de hoy" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary" android:layout_marginBottom="14dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:weightSum="3">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_schedule_time" android:padding="12dp"
                        android:gravity="center" android:layout_marginEnd="4dp">
                        <TextView android:id="@+id/tv_riego_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/green_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Riegos" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_schedule_time" android:padding="12dp"
                        android:gravity="center" android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
                        <TextView android:id="@+id/tv_tiempo_total"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0m" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/green_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tiempo total" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_schedule_time" android:padding="12dp"
                        android:gravity="center" android:layout_marginStart="4dp">
                        <TextView android:id="@+id/tv_ultimo_riego"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--:--" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/green_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Último riego" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Resumen últimos días -->
        <androidx.cardview.widget.CardView android:id="@+id/card_resumen_dias"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorCard" app:cardCornerRadius="18dp" app:cardElevation="2dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true" android:focusable="true"
            android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="📅 Resumen últimos días"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/colorTextPrimary"/>
                    <TextView android:id="@+id/tv_dias_badge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="7 días" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="@color/chipInfoText" android:background="@drawable/bg_chip_info"
                        android:paddingStart="12dp" android:paddingEnd="12dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:weightSum="3">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_schedule_time" android:padding="12dp"
                        android:gravity="center" android:layout_marginEnd="4dp">
                        <TextView android:id="@+id/tv_dias_riegos"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/green_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Riegos" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_schedule_time" android:padding="12dp"
                        android:gravity="center" android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
                        <TextView android:id="@+id/tv_dias_minutos"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/green_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Min. totales" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_schedule_time" android:padding="12dp"
                        android:gravity="center" android:layout_marginStart="4dp">
                        <TextView android:id="@+id/tv_dias_promedio"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="--" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/green_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Prom/día" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Ver historial completo →" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="@color/green_primary" android:layout_marginTop="14dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
