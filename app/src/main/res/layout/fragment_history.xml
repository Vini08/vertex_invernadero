<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/colorBg">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Historial de datos" android:textSize="16sp" android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginBottom="14dp" android:layout_marginTop="4dp"/>

        <!-- Gráfica Humedad Suelo -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="18dp" app:cardElevation="2dp" android:layout_marginBottom="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <LinearLayout android:layout_width="10dp" android:layout_height="10dp"
                        android:background="@drawable/bg_dot_green" android:layout_marginEnd="8dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Humedad suelo"
                        android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"/>
                    <LinearLayout android:id="@+id/tabs_soil"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:background="@drawable/bg_schedule_time"
                        android:padding="3dp">
                        <TextView android:id="@+id/tab_soil_24h"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="24h" android:textSize="11sp" android:textStyle="bold"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="4dp" android:paddingBottom="4dp"
                            android:textColor="@color/chipOkText" android:background="@drawable/bg_chip_ok"/>
                        <TextView android:id="@+id/tab_soil_7d"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="7d" android:textSize="11sp" android:textStyle="bold"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="4dp" android:paddingBottom="4dp"
                            android:textColor="@color/colorTextSecondary"/>
                        <TextView android:id="@+id/tab_soil_30d"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="30d" android:textSize="11sp" android:textStyle="bold"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="4dp" android:paddingBottom="4dp"
                            android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </LinearLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_soil"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Gráfica Temperatura -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="18dp" app:cardElevation="2dp" android:layout_marginBottom="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <View android:layout_width="10dp" android:layout_height="10dp"
                        android:background="@drawable/bg_dot_warn" android:layout_marginEnd="8dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Temperatura"
                        android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"/>
                    <LinearLayout android:id="@+id/tabs_temp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:background="@drawable/bg_schedule_time"
                        android:padding="3dp">
                        <TextView android:id="@+id/tab_temp_24h"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="24h" android:textSize="11sp" android:textStyle="bold"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="4dp" android:paddingBottom="4dp"
                            android:textColor="@color/chipWarnText" android:background="@drawable/bg_chip_warn"/>
                        <TextView android:id="@+id/tab_temp_7d"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="7d" android:textSize="11sp" android:textStyle="bold"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="4dp" android:paddingBottom="4dp"
                            android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </LinearLayout>

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart_temp"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Gráfica Riegos (barras) -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="18dp" app:cardElevation="2dp" android:layout_marginBottom="14dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <View android:layout_width="10dp" android:layout_height="10dp"
                        android:background="@drawable/bg_dot_green" android:layout_marginEnd="8dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Minutos de riego por día"
                        android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary"/>
                </LinearLayout>

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chart_pump"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Resumen estadístico -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="18dp" app:cardElevation="2dp" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="18dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📈 Promedios últimas 24h"
                    android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary" android:layout_marginBottom="14dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:weightSum="2">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_schedule_time" android:padding="14dp"
                        android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hum. suelo" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary"/>
                        <TextView android:id="@+id/tv_avg_soil"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="62%" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/green_primary" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="promedio" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/bg_schedule_time" android:padding="14dp"
                        android:layout_marginStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Temperatura" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary"/>
                        <TextView android:id="@+id/tv_avg_temp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="28°C" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/chipWarnText" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="promedio" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
